<section id="features">
  <div class="container">
    <h2>Features</h2>
    <p class="section-sub">Everything you need. Nothing you don't.</p>
    <div class="features-grid">
      <div class="feature">
        <div class="feature-icon">🔒</div>
        <h3>Wallet-proof access</h3>
        <p>Storage access is gated by signed, wallet-authenticated requests. No passwords, no shared API keys.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">☁️</div>
        <h3>Cloud storage first</h3>
        <p>Start with AWS regions like Milan and Frankfurt; tune for latency and data residency from day one.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">⏱️</div>
        <h3>Agent-first UX</h3>
        <p>Agents request a quote, pay, and provision storage in a single flow. No consoles, no dashboards.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔄</div>
        <h3>Automatic renewals</h3>
        <p>Monthly payments via cron jobs keep storage active. Delete the job to cancel.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔌</div>
        <h3>x402-native payments</h3>
        <p>Use x402 with USDC on Base for payments. The HTTP status code is the paywall.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">📋</div>
        <h3>Full audit trail</h3>
        <p>Every quote, payment, and storage action is tied to a transaction on-chain.</p>
      </div>
    </div>
  </div>
</section>

