<!-- ═══════════════════════════════════════════════
     ROTATING WORD SCRIPT
     Cycles through keywords in the hero headline.
     Edit the words array to match your product.
     ═══════════════════════════════════════════════ -->
<script>
(function(){
  var words=['No email 💙','No forms 💙','No logins 💙','No API keys 💙', 'Just Base 💙'];
  var i=0,el=document.getElementById('rotating-word');
  setInterval(function(){
    el.classList.add('fade-out');
    setTimeout(function(){
      i=(i+1)%words.length;
      el.textContent=words[i];
      el.classList.remove('fade-out');
    },400);
  },2500);
})();
</script>

</body>
</html>
