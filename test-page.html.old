<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☁️</text></svg>" type="image/svg+xml" sizes="any">
<style>
/* ═══════════════════════════════════════════════════════════════════════════
   STYLE UPDATES: All page styles live in this block. Change :root variables
   below for site-wide colors; then tweak the section that matches the area
   you want (nav, hero, buttons, steps, features, pricing, FAQ, footer).
   ═══════════════════════════════════════════════════════════════════════════ */

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

/* Theme: edit these to change colors site-wide. --bg = page background,
   --surface / --surface2 = cards and panels, --border = borders,
   --text = main text, --text-dim = subtitles/secondary, --accent / --accent2 = links & CTAs,
   --accent-glow = hero glow and soft highlights. */
:root{--bg:#0a0a0a;--surface:#111;--surface2:#1a1a1a;--border:#222;--text:#e8e8e8;--text-dim:#888;--accent:#60a5fa;--accent2:#3b82f6;--accent-glow:rgba(59,130,246,.15)}

html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none;transition:opacity .2s}
a:hover{opacity:.8}

/* Layout: .container width and section vertical padding. */
.container{max-width:1100px;margin:0 auto;padding:0 24px}
section{padding:100px 0}

/* Nav: bar background, blur, border, padding. .logo = size/weight; .logo span = accent color.
   .nav-links = gap and link color (default --text-dim, hover --text). */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,10,10,.85);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:16px 0}
.nav-inner{display:flex;align-items:center;justify-content:space-between}
.logo{font-size:1.2rem;font-weight:700;letter-spacing:-.02em;display:flex;align-items:center;gap:8px}
.logo span{color:var(--accent)}
.nav-links{display:flex;gap:28px;font-size:.9rem}
.nav-links a{color:var(--text-dim);transition:color .2s}
.nav-links a:hover{color:var(--text);opacity:1}

/* Hero: padding, headline size (.hero h1), gradient text (.hero h1 .highlight*), subtitle color/size.
   .hero::before = background glow (uses --accent-glow). .rotating-word = animation. .hero .trust = line under CTAs. */
.hero{padding:180px 0 120px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:800px;height:800px;background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);pointer-events:none}
.hero h1{font-size:clamp(2.8rem,6vw,4.5rem);font-weight:800;letter-spacing:-.04em;line-height:1.1;margin-bottom:20px;position:relative}
.hero h1 .highlight,.hero h1 .highlight-static{background:linear-gradient(135deg,var(--accent),#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.rotating-word{display:inline-block;min-width:5.5em;text-align:left;transition:opacity .4s ease,transform .4s ease}
.rotating-word.fade-out{opacity:0;transform:translateY(8px)}
.rotating-word.fade-in{opacity:1;transform:translateY(0)}
.hero .subtitle{font-size:clamp(1.1rem,2vw,1.35rem);color:var(--text-dim);max-width:560px;margin:0 auto 40px;line-height:1.5}
.hero .cta-row{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* Buttons: .btn = base (padding, radius, size). .btn-primary = filled CTA (gradient, shadow).
   .btn-ghost = outline. .btn-sm = full-width smaller (used in pricing). */
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:10px;font-size:1rem;font-weight:600;border:none;cursor:pointer;transition:all .2s}
.btn-primary{background:linear-gradient(135deg,var(--accent2),#2563eb);color:#fff;box-shadow:0 0 30px rgba(59,130,246,.25)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 0 40px rgba(59,130,246,.35);opacity:1}
.btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);padding:14px 28px}
.btn-ghost:hover{border-color:var(--accent);opacity:1}
.hero .trust{margin-top:48px;font-size:.85rem;color:var(--text-dim)}
.hero .trust code{background:var(--surface2);padding:3px 8px;border-radius:5px;font-size:.8rem;color:var(--accent)}

/* How it works: .steps = grid and connecting line (::before). .step-icon = box + emoji, .step-num = badge.
   .step h3 / .step p = title and body. Section headings: h2 and h2 + .section-sub. */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:60px;position:relative}
.steps::before{content:'';position:absolute;top:50px;left:16%;right:16%;height:1px;background:linear-gradient(90deg,transparent,var(--border),var(--border),transparent);z-index:0}
.step{text-align:center;position:relative;z-index:1}
.step-icon{width:80px;height:80px;margin:0 auto 20px;border-radius:20px;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:2rem}
.step-num{position:absolute;top:-8px;right:calc(50% - 52px);background:var(--accent2);color:#fff;font-size:.7rem;font-weight:700;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.step h3{font-size:1.15rem;margin-bottom:8px;font-weight:700}
.step p{color:var(--text-dim);font-size:.92rem;max-width:260px;margin:0 auto}
h2{font-size:clamp(1.8rem,3.5vw,2.5rem);font-weight:800;letter-spacing:-.03em;text-align:center}
h2+.section-sub{text-align:center;color:var(--text-dim);margin-top:12px;font-size:1.05rem}

/* Features grid: .features-grid = columns/gap. .feature = card (background, border, padding, hover).
   .feature-icon = emoji size, .feature h3 / .feature p = title and description. */
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-top:60px}
.feature{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:32px;transition:border-color .3s,transform .3s}
.feature:hover{border-color:#333;transform:translateY(-2px)}
.feature-icon{font-size:1.6rem;margin-bottom:14px}
.feature h3{font-size:1.05rem;font-weight:700;margin-bottom:8px}
.feature p{color:var(--text-dim);font-size:.9rem;line-height:1.55}

/* Pricing: .pricing-grid, .price-card (and .featured top border), .badge, .price-amount, list checkmarks.
   .launch-banner = promo strip (background, ::before top line, .launch-text gradient). Plan B can override with inline styles. */
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;margin-top:60px;max-width:720px;margin-left:auto;margin-right:auto}
.price-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:36px;position:relative;overflow:hidden}
.price-card.featured{border-color:var(--accent2)}
.price-card.featured::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),#818cf8)}
.badge{display:inline-block;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:4px 10px;border-radius:6px;background:var(--accent-glow);color:var(--accent);margin-bottom:16px}
.price-card h3{font-size:1.3rem;font-weight:700;margin-bottom:4px}
.price-amount{font-size:2.2rem;font-weight:800;margin:12px 0}
.price-amount span{font-size:.9rem;font-weight:400;color:var(--text-dim)}
.price-original{font-size:1.2rem;font-weight:500;color:var(--text-dim);text-decoration:line-through;margin-right:8px}
.launch-banner{text-align:center;margin:40px auto 0;max-width:720px;padding:20px 32px;border-radius:14px;background:linear-gradient(135deg,rgba(59,130,246,.12),rgba(129,140,248,.08));border:1px solid rgba(59,130,246,.3);position:relative;overflow:hidden}
.launch-banner::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),#818cf8,var(--accent))}
.launch-banner::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(59,130,246,.1),transparent 70%);pointer-events:none}
.launch-icon{font-size:1.8rem;display:block;margin-bottom:6px}
.launch-text{display:block;font-size:1.6rem;font-weight:900;letter-spacing:.12em;background:linear-gradient(135deg,var(--accent),#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.launch-sub{display:block;font-size:.85rem;color:var(--text-dim);margin-top:4px}
.price-card ul{list-style:none;margin:20px 0 28px}
.price-card li{padding:6px 0;font-size:.9rem;color:var(--text-dim);display:flex;align-items:center;gap:8px}
.price-card li::before{content:'✓';color:var(--accent);font-weight:700}
.btn-sm{padding:12px 24px;width:100%;justify-content:center;border-radius:10px;font-size:.95rem}

/* Footer: border, padding, .footer-links gap and link color, .footer-copy text color. */
footer{border-top:1px solid var(--border);padding:40px 0;margin-top:40px}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-links{display:flex;gap:24px;font-size:.85rem}
.footer-links a{color:var(--text-dim)}
.footer-copy{font-size:.82rem;color:#555}

/* Code block (callout + hero demo): background, border, .cmd and .comment colors. */
.code-block{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px 24px;font-family:'SF Mono',Monaco,Consolas,monospace;font-size:.85rem;color:var(--text-dim);margin-top:48px;max-width:520px;margin-left:auto;margin-right:auto;text-align:left;overflow-x:auto}
.code-block .cmd{color:var(--accent)}
.code-block .comment{color:#555}

/* Demo tabs (Tab A / Tab B): .demo-tab = inactive state, .demo-tab.active = selected. .demo-panel = content visibility. */
.demo-container{margin-top:48px;max-width:520px;margin-left:auto;margin-right:auto}
.demo-tabs{display:flex;gap:0;margin-bottom:0}
.demo-tab{padding:10px 24px;font-size:.85rem;font-weight:600;cursor:pointer;background:var(--surface2);color:var(--text-dim);border:1px solid var(--border);border-bottom:none;border-radius:10px 10px 0 0;transition:all .2s;user-select:none}
.demo-tab:first-child{margin-right:-1px}
.demo-tab.active{background:var(--surface);color:var(--text);border-color:var(--border)}
.demo-tab:not(.active):hover{color:var(--text)}
.demo-panel{display:none}
.demo-panel.active{display:block}
.demo-panel .code-block{margin-top:0;border-radius:0 10px 10px 10px}

/* Chat simulation: .chat-sim container, .chat-header, .chat-avatar (gradient), .chat-msg.human / .chat-msg.agent bubbles, .chat-msg code. */
.chat-sim{background:var(--surface);border:1px solid var(--border);border-radius:0 10px 10px 10px;padding:24px;text-align:left;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;min-height:200px}
.chat-header{display:flex;align-items:center;gap:10px;padding-bottom:16px;border-bottom:1px solid var(--border);margin-bottom:16px}
.chat-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent2),#2563eb);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.chat-name{font-size:.9rem;font-weight:600}
.chat-name span{display:block;font-size:.75rem;color:var(--text-dim);font-weight:400}
.chat-messages{display:flex;flex-direction:column;gap:12px}
.chat-msg{max-width:85%;padding:10px 14px;border-radius:12px;font-size:.88rem;line-height:1.45;opacity:0;transform:translateY(8px);animation:msgIn .4s ease forwards}
.chat-msg.human{background:var(--surface2);border:1px solid var(--border);align-self:flex-end;border-radius:12px 12px 4px 12px}
.chat-msg.agent{background:linear-gradient(135deg,rgba(59,130,246,.12),rgba(37,99,235,.08));border:1px solid rgba(59,130,246,.2);align-self:flex-start;border-radius:12px 12px 12px 4px}
.chat-msg code{background:rgba(59,130,246,.15);padding:2px 6px;border-radius:4px;font-size:.8rem;color:var(--accent)}
.chat-typing{align-self:flex-start;padding:10px 14px;opacity:0;animation:msgIn .3s ease forwards}
.chat-typing .dots{display:inline-flex;gap:4px}
.chat-typing .dots span{width:6px;height:6px;border-radius:50%;background:var(--text-dim);animation:typing 1.2s ease infinite}
.chat-typing .dots span:nth-child(2){animation-delay:.2s}
.chat-typing .dots span:nth-child(3){animation-delay:.4s}
@keyframes msgIn{to{opacity:1;transform:translateY(0)}}
@keyframes typing{0%,60%,100%{opacity:.3;transform:scale(.8)}30%{opacity:1;transform:scale(1)}}

/* FAQ: .faq-item card, summary (toggle), summary::after (+/−), body text and code. */
.faq-list{max-width:720px;margin:40px auto 0}
.faq-item{border:1px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden;background:var(--surface);transition:border-color .3s}
.faq-item:hover{border-color:#333}
.faq-item summary{padding:20px 24px;font-size:1rem;font-weight:600;cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'+';font-size:1.3rem;color:var(--accent);font-weight:300;transition:transform .2s}
.faq-item[open] summary::after{content:'−'}
.faq-item p{padding:0 24px 20px;color:var(--text-dim);font-size:.92rem;line-height:1.6}
.faq-item code{background:var(--surface2);padding:2px 7px;border-radius:4px;font-size:.85rem;color:var(--accent)}

/* Mobile: section padding, hero padding, steps layout, hide nav links, pricing/footer stack. */
@media(max-width:768px){
  section{padding:72px 0}
  .hero{padding:140px 0 80px}
  .steps{grid-template-columns:1fr;gap:40px;max-width:320px;margin-left:auto;margin-right:auto}
  .steps::before{display:none}
  .nav-links{display:none}
  .pricing-grid{grid-template-columns:1fr}
  .footer-inner{flex-direction:column;text-align:center}
}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════
     NAVIGATION
     Fixed top bar with frosted-glass blur effect.
     Replace logo emoji, brand name, and nav links.
     ═══════════════════════════════════════════════ -->
<nav>
  <div class="container nav-inner">
    <div class="logo">☁️ <span>mnemospark</span></div>
    <div class="nav-links">
      <a href="#how">How It Works</a>
      <a href="#features">Features</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
      <a href="#">Docs</a>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════
     HERO SECTION
     Centered headline with gradient text, rotating
     keyword, subtitle, CTA buttons, and tabbed
     demo area (CLI code block + chat simulation).
     ═══════════════════════════════════════════════ -->
<section class="hero">
  <div class="container">
    <h1>Wallet and go.<br><span class="highlight-static"></span> <span class="highlight rotating-word" id="rotating-word">Just Base 💙</span></h1>
    <p class="subtitle">mnemospark is an agentic service layer for OpenClaw and a standalone x402 payment and wallet-proof verification backend. It provides encrypted, authenticated, and fully autonomous access to cloud infrastructure and proprietary data, paid via x402 with USDC on Base. No human onboarding. No API keys. The blockchain transaction is the record.</p>
    <div class="cta-row">
      <a href="#" class="btn btn-primary">Get Started →</a>
      <a href="#how" class="btn btn-ghost">How It Works</a>
    </div>
    <div class="demo-container">
      <div class="demo-tabs">
        <div class="demo-tab" onclick="switchDemo('cli')">Tab A</div>
        <div class="demo-tab active" onclick="switchDemo('chat')">Tab B</div>
      </div>
      <div id="demo-cli" class="demo-panel">
        <div class="code-block">
          <span class="comment"># Step one</span><br>
          <span class="cmd">$</span> openclaw plugins install mnemospark@latest<br><br>
          <span class="comment"># Step two</span><br>
          <span class="cmd">$</span> openclaw gateway restart<br>
        </div>
      </div>
      <div id="demo-chat" class="demo-panel active">
        <div class="chat-sim" id="chatSim">
          <div class="chat-header">
            <div class="chat-avatar">🤖</div>
            <div class="chat-name">OpenClaw<span>Chat · online</span></div>
          </div>
          <div class="chat-messages" id="chatMessages"></div>
        </div>
      </div>
    </div>
    <script>
    function switchDemo(tab){
      document.querySelectorAll('.demo-tab').forEach(function(t){t.classList.remove('active')});
      document.querySelectorAll('.demo-panel').forEach(function(p){p.classList.remove('active')});
      document.querySelector('.demo-tab:'+(tab==='cli'?'first':'last')+'-child').classList.add('active');
      document.getElementById('demo-'+tab).classList.add('active');
      if(tab==='chat')runChat();
    }
    var chatRunning=false;
    document.addEventListener('DOMContentLoaded',function(){runChat()});
    function runChat(){
      if(chatRunning)return;chatRunning=true;
      var el=document.getElementById('chatMessages');
      el.innerHTML='';
      var msgs=[
        {type:'human',text:'Please install mnemospark.',delay:600},
        {type:'typing',delay:1800},
        {type:'agent',text:'I\'m on it!.',delay:400},
        {type:'typing',delay:1200},
        {type:'agent',text:'Running <code>openclaw plugins install mnemospark@latest</code>... done. Configuring your workspace now.',delay:500},
        {type:'typing',delay:2000},
        {type:'agent',text:'mnemospark is installed. View your wallet by typing /mnemospark-wallet and then deposit a little USDC on Base to start using mnemospark today!',delay:0},
      ];
      var total=0;
      msgs.forEach(function(m,i){
        total+=m.delay;
        setTimeout(function(){
          el.querySelectorAll('.chat-typing').forEach(function(t){t.remove()});
          if(m.type==='typing'){
            var d=document.createElement('div');
            d.className='chat-typing';
            d.innerHTML='<div class="dots"><span></span><span></span><span></span></div>';
            el.appendChild(d);
          }else{
            var d=document.createElement('div');
            d.className='chat-msg '+m.type;
            d.innerHTML=m.text;
            el.appendChild(d);
          }
          el.parentElement.scrollTop=el.parentElement.scrollHeight;
          if(i===msgs.length-1)setTimeout(function(){chatRunning=false},2000);
        },total);
      });
    }
    </script>
  </div>
</section>

